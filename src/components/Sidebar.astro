---
const pathname = Astro.url.pathname;
const base = import.meta.env.BASE_URL;

const isHome = pathname === base || pathname === base.slice(0, -1);
const isAbout = pathname.startsWith(`${base}about`);
---

<aside class="sidebar">
  <div class="sidebar-name">
    <div class="avatar" aria-label="Michael Lancaster">Michael Lancaster</div>
    <div class="role">Lead Frontend Engineer<br />AI Productivity Engineer</div>
  </div>

  <nav class="nav" aria-label="Page sections">
    <a href={base} class:list={[{ active: isHome }]}>Home</a>
    <a href={`${base}about/`} class:list={[{ active: isAbout }]}>About</a>
    <a href="https://linkedin.com/in/michaellancaster1" target="_blank" rel="noopener noreferrer">Experience</a>
  </nav>

  <div class="sidebar-socials">
    <div class="nav-label">Find me online</div>

    <a href="https://github.com/weblancaster" class="social-link" target="_blank" rel="noopener noreferrer">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
      github/weblancaster
    </a>

    <a href="https://linkedin.com/in/michaellancaster1" class="social-link" target="_blank" rel="noopener noreferrer">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
      linkedin/michaellancaster1
    </a>
  </div>
</aside>


