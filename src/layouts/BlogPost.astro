---
import Layout from './Layout.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  readTime?: string;
  canonicalUrl?: string;
}

const { title, description, date, tags, readTime, canonicalUrl } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "datePublished": date.toISOString(),
  "author": {
    "@type": "Person",
    "name": "Michael Lancaster",
    "url": "https://bymichaellancaster.com"
  },
  "url": canonicalUrl ?? Astro.url.href,
};
---

<Layout title={`${title} — Michael Lancaster`} description={description} canonicalUrl={canonicalUrl}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />

  <a href={import.meta.env.BASE_URL} class="post-back">
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline></svg>
    Back to home
  </a>

  <header class="post-header">
    <h1 class="post-title">{title}</h1>
    <div class="post-meta">
      <span>{formattedDate}</span>
      {readTime && <span>{readTime}</span>}
      <div class="post-tags">
        {tags.map((tag) => <span class="blog-tag">{tag}</span>)}
      </div>
    </div>
  </header>

  <div class="prose">
    <slot />
  </div>
</Layout>
