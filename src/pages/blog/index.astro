---
import Layout from '../../layouts/Layout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => data.published !== false);
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout
  title="Writing — Michael Lancaster"
  description="Technical articles on frontend engineering, React, TypeScript, performance, and engineering leadership by Michael Lancaster."
>
  <div class="blog-index-header">
    <a href="/" class="post-back">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline></svg>
      Back to home
    </a>
    <h1 class="blog-index-title">Writing</h1>
    <p class="blog-index-subtitle">{posts.length} article{posts.length !== 1 ? 's' : ''} on frontend engineering, React, TypeScript &amp; more.</p>
  </div>

  <div class="blog-list">
    {posts.map((post) => (
      <BlogCard
        href={`/blog/${post.slug}/`}
        title={post.data.title}
        excerpt={post.data.excerpt}
        date={post.data.date}
        tags={post.data.tags}
        readTime={post.data.readTime}
      />
    ))}
  </div>
</Layout>
