---
import Layout from '../layouts/Layout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => data.published !== false);
const latestPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);
---

<Layout title="Michael Lancaster — Lead Frontend Engineer & AI Productivity Engineer">

  <!-- ABOUT -->
  <section class="section" id="about">
    <div class="hero-eyebrow">Costa Mesa, CA — Available for hire</div>

    <h1 class="hero-h1">
      13+ years crafting<br /><em>frontend</em> that scales.
    </h1>

    <p class="hero-bio">
      I'm <strong>Michael Lancaster</strong>, a Staff &amp; Lead Frontend Software Engineer building
      web and mobile applications at scale. Across my 13+ years of experience, I've architected
      <strong>micro frontend systems from scratch</strong>, managed high-performing engineering teams,
      and shipped mission-critical products for companies like Mission Lane, Endpoint, and BlackBerry.
      I even designed and launched a full-stack Go/React Native startup solo as a founder.
    </p>

    <p class="hero-bio">
      My focus is the intersection of <strong>clean architecture, product velocity, and developer experience</strong>.
      I specialize in React, Next.js, and TypeScript, building robust CI/CD pipelines and testing strategies to
      accelerate entire teams. Currently scaling external experiences at <strong>Mission Lane</strong> and building
      <a href="https://www.quantaquest.ai" target="_blank" rel="noopener">QuantaQuest AI</a> for fun.
      Outside of code, I'm a <strong>Brazilian Jiu-Jitsu black belt</strong>—teaching me more about
      discipline and staying calm under pressure than any engineering book.
    </p>

    <div class="strengths">
      <span class="strength">Micro Frontends</span>
      <span class="strength">React / Next.js</span>
      <span class="strength">TypeScript</span>
      <span class="strength">GraphQL</span>
      <span class="strength">React Native</span>
      <span class="strength">Performance Optimization</span>
      <span class="strength">DX &amp; CI/CD</span>
      <span class="strength">Team Leadership</span>
      <span class="strength">AI Tooling</span>
    </div>

    <a href="mailto:michaell.llancaster@gmail.com" class="hero-cta">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
      Get in touch
    </a>
  </section>

  <!-- EXPERIENCE -->
  <section class="section" id="experience">
    <SectionHeader num="01" title="Experience" />

    <div class="exp-list">

      <article class="exp-item">
        <div>
          <div class="exp-date">Dec 2022 — Present</div>
        </div>
        <div>
          <div class="exp-company">Mission Lane</div>
          <div class="exp-role">Staff Software Engineer</div>
          <p class="exp-desc">Optimizing credit card application funnels and working across Card Dashboard Web and the mobile app using Next.js and React Native.</p>
          <div class="exp-tech">
            <span>Next.js</span><span>React Native / Expo</span><span>GraphQL</span><span>TypeScript</span>
          </div>
        </div>
      </article>

      <article class="exp-item">
        <div>
          <div class="exp-date">Feb 2021 — Nov 2022</div>
        </div>
        <div>
          <div class="exp-company">Endpoint</div>
          <div class="exp-role">Senior Software Engineer</div>
          <p class="exp-desc">Architected the entire frontend from scratch (micro frontends + web apps) and established the engineering foundation including mono-repos and CI/CD pipelines.</p>
          <div class="exp-tech">
            <span>NX.dev</span><span>Next.js</span><span>TypeScript</span><span>Cypress</span>
          </div>
        </div>
      </article>

      <article class="exp-item">
        <div>
          <div class="exp-date">Sep 2018 — Aug 2020</div>
        </div>
        <div>
          <div class="exp-company">BlackBerry</div>
          <div class="exp-role">Engineering Manager → Senior Software Architect</div>
          <p class="exp-desc">Managed 11 direct reports and led frontend architecture decisions, CI/CD improvements, and core product stability.</p>
          <div class="exp-tech">
            <span>React</span><span>TypeScript</span><span>CI/CD</span><span>Architecture</span><span>Team Leadership</span>
          </div>
        </div>
      </article>

      <div style="margin-top: 2rem;">
        <a href="https://linkedin.com/in/michaellancaster1" target="_blank" rel="noopener noreferrer" class="hero-cta" style="display: inline-flex; align-items: center;">
          View full experience on LinkedIn
          <svg style="margin-left: 8px;" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
        </a>
      </div>

    </div>
  </section>

  <!-- WRITING -->
  <section class="section" id="writing">
    <SectionHeader num="02" title="Writing" />

    <div class="blog-list">
      {latestPosts.map((post) => (
        <BlogCard
          href={`/blog/${post.slug}/`}
          title={post.data.title}
          excerpt={post.data.excerpt}
          date={post.data.date}
          tags={post.data.tags}
          readTime={post.data.readTime}
        />
      ))}
    </div>

    {allPosts.length > 5 && (
      <a href="/blog/" class="blog-view-all">
        View all {allPosts.length} posts
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
      </a>
    )}

    {allPosts.length <= 5 && allPosts.length > 0 && (
      <a href="/blog/" class="blog-view-all">
        View all posts
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
      </a>
    )}
  </section>

  <!-- TALKS & PUBLICATIONS -->
  <section class="section" id="talks">
    <SectionHeader num="03" title="Talks &amp; Publications" />

    <div class="talks-list">

      <a href="https://bymichaellancaster.com" class="talk-item" target="_blank" rel="noopener">
        <div>
          <div class="talk-name">Desktop Apps with NW.js</div>
          <div class="talk-meta">Published article &amp; guide · bymichaellancaster.com</div>
        </div>
        <span class="talk-badge pub">Publication</span>
      </a>

      <a href="https://bymichaellancaster.com" class="talk-item" target="_blank" rel="noopener">
        <div>
          <div class="talk-name">Intro to React.js</div>
          <div class="talk-meta">Published tutorial · bymichaellancaster.com</div>
        </div>
        <span class="talk-badge pub">Publication</span>
      </a>

      <a href="https://github.com/weblancaster" class="talk-item" target="_blank" rel="noopener">
        <div>
          <div class="talk-name">Open Source on GitHub</div>
          <div class="talk-meta">Contributions, side projects &amp; tooling · github.com/weblancaster</div>
        </div>
        <span class="talk-badge oss">GitHub</span>
      </a>

    </div>

    <p style="margin-top: 24px; font-size: 12px; color: var(--muted); line-height: 1.7;">
      More talks and publications coming. If you'd like me to speak at your event or contribute to your publication,
      <a href="mailto:michaell.llancaster@gmail.com" style="color: var(--accent); text-decoration: none;">get in touch</a>.
    </p>
  </section>

  <!-- OPEN SOURCE -->
  <section class="section" id="oss">
    <SectionHeader num="04" title="Open Source" />

    <div class="oss-grid">

      <a href="https://www.quantaquest.ai" class="oss-card" target="_blank" rel="noopener">
        <div class="oss-repo"><span class="org">personal / </span>QuantaQuest AI</div>
        <p class="oss-desc">AI productivity tool I'm building on the side. Exploring LLMs and developer workflows — where AI meets practical engineering.</p>
        <div class="oss-meta">
          <span><span class="lang-dot lang-ts"></span>TypeScript</span>
          <span>Active</span>
        </div>
      </a>

      <a href="https://github.com/weblancaster" class="oss-card" target="_blank" rel="noopener">
        <div class="oss-repo"><span class="org">padaone / </span>padaone.app</div>
        <p class="oss-desc">Full-stack marketplace for coaches and trainers — live video, recorded classes, payments. Built solo in 7 months with Go backend and React Native.</p>
        <div class="oss-meta">
          <span><span class="lang-dot lang-go"></span>Go + Next.js</span>
          <span>Shipped</span>
        </div>
      </a>

      <a href="https://github.com/weblancaster" class="oss-card" target="_blank" rel="noopener">
        <div class="oss-repo"><span class="org">weblancaster / </span>GitHub</div>
        <p class="oss-desc">Ongoing contributions across frontend tooling, developer experience projects, and documentation. See the full list on GitHub.</p>
        <div class="oss-meta">
          <span><span class="lang-dot lang-js"></span>JavaScript</span>
          <span>github/weblancaster</span>
        </div>
      </a>

      <a href="/blog/" class="oss-card">
        <div class="oss-repo"><span class="org">blog / </span>bymichaellancaster.com</div>
        <p class="oss-desc">Personal site and technical blog — frontend architecture, React, performance, and engineering leadership. Written for developers who want to go deeper.</p>
        <div class="oss-meta">
          <span><span class="lang-dot lang-ts"></span>Astro + Markdown</span>
          <span>Blog</span>
        </div>
      </a>

    </div>
  </section>

  <!-- SKILLS -->
  <section class="section" id="skills">
    <SectionHeader num="05" title="Skills" />

    <div class="skills-wrap">
      <div>
        <div class="skill-group-title">Frontend</div>
        <ul class="skill-list">
          <li>React.js</li>
          <li>Next.js</li>
          <li>TypeScript</li>
          <li>React Native / Expo</li>
          <li>GraphQL</li>
          <li>React Query</li>
          <li>Redux / Sagas</li>
          <li>Micro Frontends (NX)</li>
        </ul>
      </div>

      <div>
        <div class="skill-group-title">Backend &amp; Infra</div>
        <ul class="skill-list">
          <li>Node.js / Express</li>
          <li>Go / Gin-Gonic</li>
          <li>PostgreSQL</li>
          <li>Firebase / GCP</li>
          <li>Docker</li>
          <li>Cloudflare</li>
          <li>GitHub Actions</li>
          <li>Digital Ocean</li>
        </ul>
      </div>

      <div>
        <div class="skill-group-title">Testing &amp; DX</div>
        <ul class="skill-list">
          <li>Jest / React Testing Lib</li>
          <li>Cypress / Playwright</li>
          <li>Mock Service Worker</li>
          <li>Storybook</li>
          <li>CI/CD Pipelines</li>
          <li>SSR / ISR / Edge</li>
          <li>Performance Optimization</li>
          <li>Engineering Leadership</li>
        </ul>
      </div>
    </div>
  </section>

</Layout>
