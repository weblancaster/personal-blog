---
import Layout from '../layouts/Layout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => data.published !== false);
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Michael Lancaster — Lead Frontend Engineer & AI Productivity Engineer">

  <!-- WRITING -->
  <section class="section" id="writing">
    <SectionHeader num="01" title="Writing" />

    <div class="blog-list">
      {posts.map((post) => (
        <BlogCard
          href={`${import.meta.env.BASE_URL}blog/${post.slug}/`}
          title={post.data.title}
          excerpt={post.data.excerpt}
          date={post.data.date}
          tags={post.data.tags}
          readTime={post.data.readTime}
        />
      ))}
    </div>
  </section>

</Layout>
